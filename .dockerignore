# Ignore all Git files
.git/
.gitignore

# Node modules and build files
node_modules/
dist/
dist-ssr/
build/

# Ignore massive model caches and local databases
hf_model_cache/
qdrant_data/
neo4j_data/
redis_data/
telemetry_data/
