# Ignore all Git files
.git/
.gitignore

# Node modules and build files
node_modules/
dist/
dist-ssr/
build/

# Ignore massive model caches and local databases
hf_model_cache/
qdrant_data/
neo4j_data/
redis_data/
telemetry_data/
rag_storage/
knowledge/
.data/
data/
transcripts/

# Ignore agent artifacts
.code-review-graph/
.gemini/
.claude/
.agent/
.agents/
.understand-anything/
.codegraph/
.graphify/
mcp-servers/

# Ignore Python virtual environments
.venv/
backend/.venv/
venv/
.venv_whisper/
.venv_host/

# Ignore cloned repos and PDF generators
book-to-skill/
backend/repos/
external_repos/

# Ignore Kubernetes/docker config — not needed in image
k8s/
infrastructure/
docker-compose*.yml

# Ignore development/ops scripts — not needed at runtime
scripts/
benchmarks/
Makefile

# Ignore large log files
**/*.log
nohup.out

# Editor files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Exclude test/benchmark directories (not needed in production image)
tests/
**/test_*.py
**/*_test.py

# Exclude markdown and notebook files (docs don't belong in image)
*.md
*.ipynb
.ipynb_checkpoints/

# Exclude Python bytecode
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd

# Exclude environment files (secrets must not leak into image)
.env*
!.env.example

# Exclude planning and task artifacts
.planning/
.clinerules/
.cursor/
.opencode/
.windsurf/
.worktrees/
