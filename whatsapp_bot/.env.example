ASKMUKTHIGURU_API_URL=https://your-backend-host.com
JWT_SECRET=replace_with_value_matching_backend_dotenv_JWT_SECRET

# From Twilio console — Auth Token (NOT account SID). Used to validate inbound webhooks.
TWILIO_AUTH_TOKEN=replace_with_twilio_auth_token

# WhatsApp sender number. Sandbox: whatsapp:+14155238886. Production: your purchased WA number.
TWILIO_FROM=whatsapp:+14155238886

# Optional
WA_DB_PATH=./wa_state.db
WA_CHAT_TIMEOUT_S=60
WA_HISTORY_LIMIT=10
PORT=8080
