# ============================================================
# Mukthi Guru — Example Environment Configuration
# Copy to .env and fill in values. Do NOT commit .env to git.
# ============================================================

# --- LLM PROVIDER ---
# Options: "sarvam_cloud" (default), "ollama", "openrouter", "nim"
LLM_PROVIDER=sarvam_cloud

# --- SARVAM CLOUD API ---
SARVAM_API_KEY=
SARVAM_CLOUD_MODEL=sarvam-30b
SARVAM_CLOUD_CLASSIFY_MODEL=sarvam-30b
SARVAM_RPM_LIMIT=60

# --- OPENROUTER ---
OPENROUTER_API_KEY=
OPENROUTER_GENERATION_MODEL=google/gemini-3.6-flash
OPENROUTER_CLASSIFY_MODEL=meta-llama/llama-3.1-8b-instruct
OPENROUTER_FAST_MODEL=meta-llama/llama-3.1-8b-instruct
USE_OPENROUTER_FOR_SIMPLE=false

# --- NVIDIA NIM ---
NIM_API_KEY=
NIM_GENERATION_MODEL=meta/llama-3.1-8b-instruct
NIM_CLASSIFY_MODEL=meta/llama-3.1-8b-instruct
NIM_RPM_LIMIT=30

# --- MODEL PRESET (Ollama only) ---
MODEL_PRESET=qwen
OLLAMA_MODEL=
OLLAMA_CLASSIFY_MODEL=
OLLAMA_BASE_URL=http://localhost:11434

# --- YOUTUBE INGESTION ---
# Webshare.io residential proxy (free: 10 proxies). Bypasses YouTube's GCP IP block.
# Set this on both the web API and celery-worker Railway services.
# Sign up: https://webshare.io → get proxy URL like http://user:pass@host:port
WEBSHARE_PROXY_URL=
# Base64-encoded cookies.txt from a logged-in YouTube session.
# Export via browser extension (e.g. "Get cookies.txt" for Chrome).
#   cat cookies.txt | base64 | pbcopy   # macOS, then paste as Railway env var
# This is safer than mounting a file — no filesystem dependency.
YOUTUBE_COOKIES_B64=

# --- INFRASTRUCTURE ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=spiritual_wisdom
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# --- SUPABASE ---
SUPABASE_URL=http://localhost:54321
SUPABASE_KEY=
JWT_SECRET=
SUPABASE_ANON_KEY=

# --- SECOND BRAIN (Mukthi Vault) ---
# Mode-A server-side KEK, wraps each user's per-user DEK. Generate with:
#   openssl rand -base64 32
# Rotating this orphans previously-wrapped DEKs — plan a re-wrap migration
# job before rotating in production. Optional: without it, vault provisioning
# fails closed (503) rather than falling back to an unwrapped/weak key.
BRAIN_KEK=

# --- GOOGLE OAUTH ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- FACEBOOK OAUTH ---
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# --- SERVER ---
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080
RATE_LIMIT_PER_MINUTE=10

# --- BENCHMARKS ---
# Optional secret for local benchmark auth backdoor (X-Test-Key header).
# Only used when ENABLE_TEST_AUTH=true and IS_PRODUCTION=false are also set.
# If unset, falls back to JWT_SECRET for backward compatibility.
BENCHMARK_SECRET=

# --- CELERY ---
# Task visibility timeout (seconds). Must be > longest task duration. Default 3600 (1 hour).
CELERY_BROKER_VISIBILITY_TIMEOUT=3600
# OpenAI API key for Whisper transcription (pay-per-use fallback). Optional.
OPENAI_API_KEY=

# --- AUTH BACKDOOR (LOCAL DEV ONLY) ---
# NEVER enable in production. These enable the X-Test-Key benchmark auth.
# IS_PRODUCTION=false
# ENABLE_TEST_AUTH=true

# --- INGESTION SERVICES ---
# Supadata API key for managed YouTube transcript fallback. Free tier: 100 req/month.
SUPADATA_API_KEY=

