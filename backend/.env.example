# ============================================================
# Mukthi Guru — Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# ============================================================
# LLM PROVIDER (Choose your backend)
# ============================================================
# Options:
#   "sarvam_cloud" → Sarvam Cloud API (recommended, free tier)  [DEFAULT]
#   "ollama"       → Local Ollama (requires model downloads)
LLM_PROVIDER=sarvam_cloud

# ============================================================
# SARVAM CLOUD API (only needed if LLM_PROVIDER=sarvam_cloud)
# ============================================================
SARVAM_API_KEY=                                     # Get from https://dashboard.sarvam.ai/
SARVAM_CLOUD_MODEL=sarvam-30b                       # sarvam-30b (64K ctx) or sarvam-105b (128K ctx)
SARVAM_CLOUD_CLASSIFY_MODEL=sarvam-30b              # Same model, lower max_tokens for classification

# ============================================================
# MODEL PRESET (Ollama mode only — ignored when LLM_PROVIDER=sarvam_cloud)
# ============================================================
# Options:
#   "qwen"    → Qwen3-30B-A3B (generation) + Qwen3-14B (classification)  [DEFAULT — works with `ollama pull`]
#   "sarvam"  → Sarvam 30B (generation) + llama3.2:3b (classification)   [Requires custom GGUF import, see DEPLOY.md]
#   "custom"  → Uses OLLAMA_MODEL + OLLAMA_CLASSIFY_MODEL below
MODEL_PRESET=qwen

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=spiritual_wisdom
QDRANT_LOCAL_PATH=                          # Set to a path for local mode (no Docker). Leave empty for Docker.

# --- Embeddings ---
EMBEDDING_MODEL=BAAI/bge-m3                    # Multilingual (100+ languages), 1024d, native dense+sparse
EMBEDDING_DIMENSION=1024
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Whisper / Transcription ---
WHISPER_MODEL=large-v3
WHISPER_BACKEND=faster-whisper              # Options: faster-whisper (4x faster), openai-whisper
WHISPER_COMPUTE_TYPE=float16                # GPU: float16, CPU: int8 or float32

# --- Transcript Extraction ---
TRANSCRIPT_LANGUAGES=en,hi,te,ta,kn,ml,bn,gu,mr,pa   # 10 Indian languages supported
TRANSCRIPT_MAX_RETRIES=3                    # Retry per tier before falling to next
TRANSCRIPT_CONCURRENT_WORKERS=4             # Concurrent workers for playlist/channel ingestion

# --- OCR ---
OCR_LANGUAGES=en,hi,te

# --- Server ---
# ⚠️ SECURITY: 0.0.0.0 binds to ALL network interfaces (accessible from LAN/internet).
# Use 127.0.0.1 for local-only access. Only use 0.0.0.0 in Docker or behind a reverse proxy.
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:3000

# --- RAPTOR ---
RAPTOR_CLUSTER_SIZE=8                       # Chunks per cluster for summarization
# RAPTOR_SUMMARY_MODEL=                     # Auto-resolved from MODEL_PRESET

# --- RAG ---
RAG_TOP_K_RETRIEVAL=20                      # Broad retrieval from Qdrant
RAG_TOP_K_RERANK=5                          # After CrossEncoder reranking (top-5 for better context)
RAG_MAX_REWRITES=3                          # Max CRAG rewrite attempts
RAG_CHUNK_SIZE=1500                         # Characters per chunk (~300 tokens, 5x context utilization)
RAG_CHUNK_OVERLAP=200                       # Overlap between chunks (preserves cross-boundary context)
RAG_USE_HYDE=true                           # Enable Hypothetical Document Embeddings for better retrieval
