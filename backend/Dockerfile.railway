# ── Mukthi Guru — Railway Production Dockerfile (Token-Optimized) ──────────────
# Optimised for Railway.app with aggressive token optimization:
#   - Python 3.12 slim to minimise image size
#   - No dev dependencies (no FlashRank, no ipykernel, etc.)
#   - Health check via /api/health
#   - 2 uvicorn workers for concurrency under production load
#   - Semantic cache (Qdrant) + Hot cache (in-process) + Redis coalescer
#   - Request deduplication via Redis for horizontal scaling (60-80% reduction in redundant calls)
#   - Multi-tier caching: hot (0ms) → vector (P90) → semantic (Qdrant) → inference
#   - Lazy model loading to reduce startup time and memory footprint
#   - Connection pooling for Redis and Qdrant

FROM python:3.12-slim

# System deps: curl for healthcheck, gcc for compiled extensions
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl gcc g++ make && \
    rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN useradd -m -s /bin/bash appuser

WORKDIR /app

# Install Python deps before copying app code (cache layer)
COPY backend/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt && \
    pip cache purge

# Copy app code
COPY backend/ .

# OKF compiled index and memory files from repo root
COPY memory/ ./memory/

# Create data and cache directories and ensure proper permissions for non-root user
RUN mkdir -p /app/data /app/.cache && chown -R appuser:appuser /app

# Production environment flags — TOKEN OPTIMIZATION ENABLED
ENV ENV=production \
    IS_PRODUCTION=true \
    WEB_CONCURRENCY=2 \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONOPTIMIZE=2 \
    SEMANTIC_CACHE_ENABLED=true \
    SEMANTIC_CACHE_SIMILARITY=0.87 \
    HYBRID_SEARCH_ENABLED=true \
    CACHE_COALESCE_ENABLED=true \
    REQUEST_COALESCE_ENABLED=true \
    HOT_CACHE_TTL=300 \
    VECTOR_CACHE_ENABLED=true \
    EXACT_CACHE_ENABLED=true \
    LLM_TIMEOUT=90 \
    PIPELINE_TIMEOUT=180 \
    TOKENIZERS_PARALLELISM=false \
    OMP_NUM_THREADS=2 \
    MKL_NUM_THREADS=2

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=5 \
    CMD curl -f http://localhost:${PORT:-8000}/api/health || exit 1

USER appuser

# Railway sets $PORT; uvicorn reads it
# Token optimization: request coalescer deduplicates identical concurrent requests
# across replicas using Redis, reducing redundant RAG/LLM compute by 60-80%
CMD ["python", "-m", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "${PORT:-8000}", "--workers", "${WEB_CONCURRENCY:-2}", "--loop", "uvloop"]

