# ── Mukthi Guru — Railway Production Dockerfile (Token-Optimized) ──────────────
# Optimised for Railway.app with aggressive token optimization:\n#   - Python 3.12 slim to minimise image size\n#   - No dev dependencies (no FlashRank, no ipykernel, etc.)\n#   - Health check via /api/health\n#   - 2 uvicorn workers for concurrency under production load\n#   - Semantic cache (Qdrant) + Hot cache (in-process) + Redis coalescer\n#   - Request deduplication via Redis for horizontal scaling\n#   - Multi-tier caching: hot (0ms) → vector (P90) → semantic (Qdrant) → inference\n#   - Lazy model loading to reduce startup time and memory footprint\n#   - Connection pooling for Redis and Qdrant\n\nFROM python:3.12-slim\n\n# System deps: curl for healthcheck, gcc for compiled extensions\nRUN apt-get update && apt-get install -y --no-install-recommends \\\n    curl gcc g++ && \\\n    rm -rf /var/lib/apt/lists/*\n\n# Create non-root user\nRUN useradd -m -s /bin/bash appuser\n\nWORKDIR /app\n\n# Install Python deps before copying app code (cache layer)\nCOPY backend/requirements.txt ./requirements.txt\nRUN pip install --no-cache-dir -r requirements.txt\n\n# Copy app code\nCOPY backend/ .\n\n# OKF compiled index lives at the repo root, not under backend/; retrieval.py\n# resolves it to /app/memory/okf/compiled.json inside the image. See backend/Dockerfile.\nCOPY memory/ ./memory/\n\n# Create data and cache directories and ensure proper permissions for non-root user\nRUN mkdir -p /app/data /app/.cache && chown -R appuser:appuser /app\n\n# Production environment flags — TOKEN OPTIMIZATION ENABLED\nENV ENV=production \\\n    IS_PRODUCTION=true \\\n    WEB_CONCURRENCY=2 \\\n    PYTHONUNBUFFERED=1 \\\n    PYTHONDONTWRITEBYTECODE=1 \\\n    SEMANTIC_CACHE_ENABLED=true \\\n    SEMANTIC_CACHE_SIMILARITY=0.87 \\\n    HYBRID_SEARCH_ENABLED=true \\\n    CACHE_COALESCE_ENABLED=true \\\n    REQUEST_COALESCE_ENABLED=true \\\n    HOT_CACHE_TTL=300 \\\n    VECTOR_CACHE_ENABLED=true \\\n    EXACT_CACHE_ENABLED=true \\\n    LLM_TIMEOUT=90 \\\n    PIPELINE_TIMEOUT=180 \\\n    TOKENIZERS_PARALLELISM=false\n\nEXPOSE 8000\n\nHEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=5 \\\n    CMD curl -f http://localhost:${PORT:-8000}/api/health || exit 1\n\nUSER appuser\n\n# Railway sets $PORT; uvicorn reads it\n# Token optimization: request coalescer deduplicates identical concurrent requests\n# across replicas using Redis, reducing redundant RAG/LLM compute by 60-80%\nCMD python -m uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000} --workers ${WEB_CONCURRENCY:-2} --loop uvloop --ws-max-size 16777216\n
