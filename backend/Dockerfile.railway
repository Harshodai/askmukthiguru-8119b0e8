# ── Mukthi Guru — Railway Production Dockerfile (Token-Optimized) ──────────────
# Optimised for Railway.app with aggressive token optimization:
#   - Python 3.12 slim to minimise image size
#   - No dev dependencies (no FlashRank, no ipykernel, etc.)
#   - Health check via /api/health
#   - 2 uvicorn workers for concurrency under production load
#   - Semantic cache (Qdrant) + Hot cache (in-process) + Redis coalescer
#   - Request deduplication via Redis for horizontal scaling (60-80% reduction in redundant calls)
#   - Multi-tier caching: hot (0ms) → vector (P90) → semantic (Qdrant) → inference
#   - Lazy model loading to reduce startup time and memory footprint
#   - Connection pooling for Redis and Qdrant

FROM python:3.12-slim

# ── Cache Buster ──
# This arg is filled by railway up (or buildx) with the commit hash.
# It busts the Docker build cache on every new commit. Platforms without
# --build-arg support will silently ignore it (no effect on dev).
ARG GIT_COMMIT
RUN echo "Build: ${GIT_COMMIT:-$(date +%s)}" > /dev/null

# System deps: curl for healthcheck, gcc for compiled extensions
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl gcc g++ make && \
    rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN useradd -m -s /bin/bash appuser

WORKDIR /app

# Install Python deps before copying app code (cache layer)
COPY backend/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt && \
    pip cache purge

# Pre-cache the primary embedding model at build time — avoids the runtime
# cold-start download (and the corruption/OOM risk under Railway's constrained
# resources) that caused the 2026-07-16 dimension-mismatch incident. See
# CLAUDE.md "Embedding dimension contract". HF_HOME must match at runtime
# (unset elsewhere, so this is the only place it's defined) for the encoder
# load in embedding_service.py to hit this cache instead of re-downloading.
# Pinned to commit hash 3a90cc8b42f5acec95e57c1e2433ba3b71ba9eef so the
# digest is immutable across rebuilds — see lessons.md "Embedding dimension
# contract" for the full incident analysis.
ENV HF_HOME=/app/.cache/huggingface
RUN mkdir -p /app/.cache/huggingface && chown -R appuser:appuser /app/.cache
USER appuser
RUN python -c "from FlagEmbedding import BGEM3FlagModel; BGEM3FlagModel('BAAI/bge-m3', revision='3a90cc8b42f5acec95e57c1e2433ba3b71ba9eef', use_fp16=False, device='cpu')"
USER root

# Copy app code with explicit ownership
COPY --chown=appuser:appuser backend/ .

# OKF compiled index and memory files from repo root
COPY --chown=appuser:appuser memory/ ./memory/

# Create data and logs directories with proper ownership for non-root runtime user
RUN mkdir -p /app/data /app/logs && chown -R appuser:appuser /app/data /app/logs

# Production environment flags — TOKEN OPTIMIZATION ENABLED
ENV ENV=production \
    IS_PRODUCTION=true \
    WEB_CONCURRENCY=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONOPTIMIZE=1 \
    SEMANTIC_CACHE_ENABLED=true \
    SEMANTIC_CACHE_SIMILARITY=0.87 \
    HYBRID_SEARCH_ENABLED=true \
    CACHE_COALESCE_ENABLED=true \
    REQUEST_COALESCE_ENABLED=true \
    HOT_CACHE_TTL=300 \
    VECTOR_CACHE_ENABLED=true \
    EXACT_CACHE_ENABLED=true \
    LLM_TIMEOUT=90 \
    PIPELINE_TIMEOUT=180 \
    TOKENIZERS_PARALLELISM=false \
    OMP_NUM_THREADS=2 \
    MKL_NUM_THREADS=2 \
    PEFT_FAST_IMPORT_MODE=1

EXPOSE 8000

USER appuser

# Railway sets $PORT; uvicorn reads it via start_railway.py (which overrides CMD).
# This CMD is the fallback when running outside Railway (e.g. local Docker).
# exec form cannot expand env vars; use shell form instead.
CMD python -m uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000} --workers ${WEB_CONCURRENCY:-1} --loop uvloop

