# =============================================================================
# AskMukthiGuru — Production Environment Configuration
# =============================================================================
# Copy this file to .env and fill in all values marked <REQUIRED>
# =============================================================================

# =============================================================================
# LLM Provider Selection
# =============================================================================
# Options: sarvam_cloud | ollama | openrouter | anthropic | emergent
LLM_PROVIDER=sarvam_cloud

# Ollama model preset (only when LLM_PROVIDER=ollama)
# Options: qwen | sarvam | custom
MODEL_PRESET=qwen

# Model name override for scripts
SARVAM_MODEL_NAME=sarvam-30b:latest

# =============================================================================
# Sarvam Cloud API
# =============================================================================
SARVAM_API_KEY=<REQUIRED>
SARVAM_BASE_URL=https://api.sarvam.ai/v1
SARVAM_CLOUD_MODEL=sarvam-30b
SARVAM_CLOUD_CLASSIFY_MODEL=sarvam-30b
SARVAM_CLOUD_COMPLEX_MODEL=sarvam-105b
SARVAM_COMPLEX_ROUTING_ENABLED=false
SARVAM_COMPLEX_CONTEXT_CHARS=20000

# Reasoning effort: low | medium | high
SARVAM_REASONING_EFFORT=medium
SARVAM_REASONING_EFFORT_FAST=low
SARVAM_REASONING_EFFORT_COMPLEX=high

# =============================================================================
# OpenRouter (free tier for simple queries)
# =============================================================================
OPENROUTER_API_KEY=<REQUIRED>
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_FAST_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
OPENROUTER_GENERATION_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_CLASSIFY_MODEL=meta-llama/llama-3.1-8b-instruct
USE_OPENROUTER_FOR_SIMPLE=true
OPENROUTER_RPM_LIMIT=20

# =============================================================================
# Ollama (local mode)
# =============================================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=
OLLAMA_CLASSIFY_MODEL=

# =============================================================================
# Emergent / LLM Gateway (unified provider chain)
# =============================================================================
EMERGENT_LLM_KEY=
LLM_PROVIDER_CHAIN=anthropic:claude-sonnet-4-6,anthropic:claude-haiku-4-5-20251001,openai:gpt-5.4
LLM_GATEWAY_STREAMING_DEFAULT=true
LLM_GATEWAY_SESSION_PREFIX=mukthi-guru
LLM_GATEWAY_MAX_TOKENS=4096
LLM_GATEWAY_REQUEST_TIMEOUT_S=60

# =============================================================================
# Anthropic Gateway (direct API with prompt caching)
# =============================================================================
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_API_VERSION=2023-06-01
ANTHROPIC_BETA_FEATURES=prompt-caching-2024-07-31
ANTHROPIC_GATEWAY_MODEL=claude-sonnet-4-6
ANTHROPIC_GATEWAY_MAX_TOKENS=2048
ANTHROPIC_GATEWAY_TEMPERATURE=0.7
ANTHROPIC_GATEWAY_TIMEOUT_S=60
ANTHROPIC_GATEWAY_CACHE_TTL=1h
ANTHROPIC_EXTENDED_THINKING_ENABLED=false
ANTHROPIC_EXTENDED_THINKING_BUDGET_TOKENS=0

# =============================================================================
# LLM Timeouts & Retries
# =============================================================================
LLM_TIMEOUT=60
PIPELINE_TIMEOUT=180
PIPELINE_TIMEOUT_BUDGET=300
LLM_MAX_RETRIES=2
NODE_TIMEOUT_FAST=20
NODE_TIMEOUT_MAIN=90

# =============================================================================
# Krutrim (fallback Indian LLM)
# =============================================================================
KRUTRIM_API_KEY=

# =============================================================================
# Server
# =============================================================================
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# =============================================================================
# Security & Auth
# =============================================================================
IS_PRODUCTION=true
ENABLE_TEST_AUTH=false
JWT_SECRET=<REQUIRED>
SUPABASE_JWT_AUDIENCE=authenticated
CSRF_SECRET=<REQUIRED>
CSRF_TOKEN_TTL=3600
CORRELATION_ID_MAX_LENGTH=64
ALLOWED_HOSTS=your-domain.com,api.your-domain.com
DISABLE_PUBLIC_REGISTRATION=true
BENCHMARK_SECRET=

# =============================================================================
# Rate Limiting
# =============================================================================
CHAT_RATE_LIMIT=20/minute
REGISTRATION_RATE_LIMIT=5/minute
ADMIN_RATE_LIMIT=5/minute

# =============================================================================
# Supabase (Auth & Persistence)
# =============================================================================
SUPABASE_URL=<REQUIRED>
SUPABASE_KEY=<REQUIRED>  # SERVICE_ROLE_KEY for backend write access
SUPABASE_ANON_KEY=<REQUIRED>

# =============================================================================
# Qdrant (Vector Database)
# =============================================================================
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=spiritual_wisdom
QDRANT_LOCAL_PATH=  # Set for local non-Docker mode, leave empty for Docker

# =============================================================================
# Neo4j (Knowledge Graph)
# =============================================================================
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=<REQUIRED>

# =============================================================================
# Redis (Cache & Queue)
# =============================================================================
REDIS_URL=<REQUIRED>  # e.g., redis://:password@redis:6379/0
REDIS_PASSWORD=<REQUIRED>

# Cache mode: best_effort | redis | memory
CACHE_MODE=best_effort

# =============================================================================
# Embeddings
# =============================================================================
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
EMBEDDING_CACHE_SIZE=10000

# =============================================================================
# RAG Pipeline
# =============================================================================
RAG_TOP_K_RETRIEVAL=20
RAG_TOP_K_RERANK=10
RAG_MAX_REWRITES=1
RAG_CHUNK_SIZE=1500
RAG_CHUNK_OVERLAP=200
RAG_USE_HYDE=true
RAG_CONTEXT_WINDOW=2
RERANK_MIN_SCORE=0.35
RAG_USE_CONTEXT_COMPRESSION=false
RAG_CONTEXT_COMPRESSION_THRESHOLD=10000
RAG_MMR_LAMBDA=0.5
RAG_TOP_K_RETRIEVAL_AFTER_CUTOFF=10
RAG_COMPRESSION_SIMILARITY_THRESHOLD=0.50
RAG_CACHE_ALIGNMENT_ENABLED=true
RAG_CONTEXT_COMPRESSION_ENABLED=true
MAX_TOKENS_PER_REQUEST=12000

# =============================================================================
# Retrieval Quality Gates
# =============================================================================
RETRIEVAL_SCORE_DELTA_ENABLED=true
RETRIEVAL_DEDUPLICATION_ENABLED=true
RETRIEVAL_DEDUP_THRESHOLD=0.85
INGESTION_DEDUPLICATION_ENABLED=true
INGESTION_DEDUP_THRESHOLD=0.85
RAPTOR_PARENT_SUMMARIES_ENABLED=true
USE_MARKITDOWN_PARSER=true

# =============================================================================
# FlashRank Reranking & Ingestion
# =============================================================================
USE_FLASHRANK=true
FLASHRANK_MODEL=auto
USE_ADAPTIVE_CHUNKING=true
ADAPTIVE_CHUNKING_MIN_CHARS=5000
USE_INGEST_ADAPTIVE_CHUNKER=true
USE_BOUNDARY_CHUNKER=false
USE_PROPOSITION_CHUNKING=auto
PROPOSITION_CHAR_LIMIT=15000

# =============================================================================
# Hyper-Extract Enrichment
# =============================================================================
USE_HYPER_EXTRACT_ENRICHMENT=false
HYPER_EXTRACT_MIN_CHARS=200
HYPER_EXTRACT_MAX_CHARS=50000

# =============================================================================
# RAPTOR (Summarization Clustering)
# =============================================================================
RAPTOR_CLUSTER_SIZE=8
RAPTOR_SUMMARY_MODEL=  # Auto-set from model_preset

# =============================================================================
# Semantic Cache
# =============================================================================
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_SIMILARITY=0.90
SEMANTIC_CACHE_TTL=604800
SEMANTIC_CACHE_QDRANT_COLLECTION=semantic_cache
SEMANTIC_CACHE_HNSW_EF=128
USE_QDRANT_SEMANTIC_CACHE=true

# =============================================================================
# Hybrid Search (P90/P99)
# =============================================================================
HYBRID_SEARCH_ENABLED=true
P90_CONFIDENCE_THRESHOLD=0.8
P99_TIMEOUT_MS=5000
FAISS_CACHE_SIZE=500

# =============================================================================
# Guardrails
# =============================================================================
# Provider: nemo | lightweight | disabled
GUARDRAILS_PROVIDER=nemo
GUARDRAILS_AUDIT_ENABLED=true
GUARDRAILS_LLM_ENABLED=false

# =============================================================================
# Whisper / Transcription
# =============================================================================
WHISPER_MODEL=large-v3
WHISPER_BACKEND=faster-whisper
WHISPER_COMPUTE_TYPE=float16
WHISPER_LOCAL_MODEL=mlx-community/whisper-large-v3-turbo
WHISPER_LOCAL_DEVICE=mps

# =============================================================================
# Transcript Extraction
# =============================================================================
TRANSCRIPT_LANGUAGES=en,hi,bn,te,mr,ta,ur,gu,kn,ml,or,pa,as,mai,sa,ks,ne,sd,kok,doi,mni,sat,brx
TRANSCRIPT_MAX_RETRIES=3
TRANSCRIPT_CONCURRENT_WORKERS=1  # Keep at 1 to avoid YouTube 429 rate limits

# =============================================================================
# Transcript Council (Dual-STT Quality)
# =============================================================================
ENABLE_TRANSCRIPT_COUNCIL=true
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_MODE=transcribe
SARVAM_STT_LANGUAGE=en-IN
STT_CHUNK_MINUTES=55
STT_MAX_AUDIO_MB=200

# =============================================================================
# OCR
# =============================================================================
OCR_LANGUAGES=en,hi

# =============================================================================
# Job Queue & Backpressure
# =============================================================================
QUEUE_ENABLED=true
QUEUE_MAX_SIZE=50
QUEUE_CONCURRENCY=5
QUEUE_JOB_TTL=1800
QUEUE_DEFAULT_TIMEOUT=300

# =============================================================================
# LLM Queue (Concurrency Gating)
# =============================================================================
LLM_QUEUE_ENABLED=true
LLM_QUEUE_MAX_CONCURRENT=5
LLM_QUEUE_MAXSIZE=50

# =============================================================================
# Feature Flags & Memory Layer
# =============================================================================
FEATURE_MEMORY_ENABLED=true
FEATURE_MEMORY_WRITE=true
FEATURE_LIGHTWEIGHT_CLASSIFIER=false
FEATURE_REGEX_PREROUTER=true
SERENE_MIND_ENABLED=true

# =============================================================================
# Semantic Model Router (embedding-based classification)
# =============================================================================
SEMANTIC_ROUTER_ENABLED=true
SEMANTIC_ROUTER_TOP_K=3
SEMANTIC_ROUTER_CONFIDENCE_THRESHOLD=0.65
SEMANTIC_ROUTER_FALLBACK_LLM=false
SEMANTIC_ROUTER_SHADOW_MODE=false
USE_SEMANTIC_ROUTER=true
SEMANTIC_ROUTER_LLM_FALLBACK=true
ROUTER_CONFIG_PATH=  # Empty = use bundled default at backend/config/router_routes.yaml

# =============================================================================
# Safety Limits
# =============================================================================
CHAT_HISTORY_MAX_MESSAGES=20
MAX_INPUT_LENGTH=2000

# =============================================================================
# Temperature per Graph Mode
# =============================================================================
GENERATION_TEMP_FAST=0.3
GENERATION_TEMP_STANDARD=0.7
GENERATION_TEMP_DEEP=0.9
GENERATION_TOP_K_FAST=40
GENERATION_TOP_K_STANDARD=50
GENERATION_TOP_K_DEEP=100
GENERATION_TOP_P_STANDARD=0.9
GENERATION_TOP_P_DEEP=0.95

# =============================================================================
# Context Budget
# =============================================================================
CONTEXT_BUDGET_ENABLED=true
CONTEXT_WINDOW_TOTAL=8192
CONTEXT_SYSTEM_PROMPT_RESERVE=0.20
CONTEXT_HISTORY_RESERVE=0.10

# =============================================================================
# Idempotency
# =============================================================================
IDEMPOTENCY_TTL_SECONDS=86400
IDEMPOTENCY_REDIS_PREFIX=idempotency:

# =============================================================================
# User Profiles & Persistence
# =============================================================================
USER_PROFILE_ENABLED=true

# =============================================================================
# Proactive Serene Mind (Distress Detection)
# =============================================================================
PROACTIVE_SERENE_MIND_ENABLED=true
PROACTIVE_DISTRESS_AVG_THRESHOLD=1.5
PROACTIVE_DISTRESS_TREND_THRESHOLD=0.5
PROACTIVE_DISTRESS_FREQUENCY_THRESHOLD=0.6
PROACTIVE_MIN_CONVERSATION_POINTS=3

# =============================================================================
# A/B Testing
# =============================================================================
AB_TESTING_ENABLED=false
AB_TESTING_RATIO=0.1

# =============================================================================
# Web Search (Temporal Queries)
# =============================================================================
WEB_SEARCH_ENABLED=false
WEB_SEARCH_PROVIDER=duckduckgo  # duckduckgo | searxng
WEB_SEARCH_ALLOWED_DOMAINS=ekam.org,theonenessmovement.org
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT=10
WEB_SEARCH_PARALLEL=true
SEARXNG_URL=http://searxng:8080

# =============================================================================
# Observability
# =============================================================================
ENABLE_CORRELATION_IDS=true

# =============================================================================
# Meditation Routing
# =============================================================================
MEDITATION_MAX_STEP=4
MEDITATION_START_STEP=1
INTENT_DEMOTE_MEDITATION_ON_INTERROGATIVE=true
MEDITATION_SAFE_FALLBACK=true

# =============================================================================
# Persona Controls (Guru Voice Quality)
# =============================================================================
STRIP_CANNED_FOOTER=true
PERSONA_MAX_PARAGRAPHS=4
PERSONA_MAX_SENTENCE_WORDS=35

# =============================================================================
# LLM Judge (Eval)
# =============================================================================
LLM_JUDGE_PROVIDER_MODEL=anthropic:claude-sonnet-4-6
LLM_JUDGE_SESSION_PREFIX=mukthi-guru-judge

# =============================================================================
# Thresholds (de-hardcoded magic numbers)
# =============================================================================
LETTUCE_DETECT_THRESHOLD=0.25
COVE_SUPPORTED_THRESHOLD=0.8
COVE_PARTIAL_THRESHOLD=0.5
FAITHFULNESS_FLOOR=0.8
VERIFIER_PASS_RATIO=0.5
RERANK_THRESHOLD_COMPLEX=0.01
RERANK_THRESHOLD_SIMPLE=0.05
RERANK_FLOOR=0.3
CROSS_ENCODER_CUTOFF=20

# =============================================================================
# HTTP Connection Pooling
# =============================================================================
HTTP_MAX_CONNECTIONS=100
HTTP_MAX_KEEPALIVE_CONNECTIONS=20
HTTP_KEEPALIVE_EXPIRY=30.0

# =============================================================================
# Database Connection Pooling
# =============================================================================
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_PRE_PING=true
DB_POOL_RECYCLE=3600

# =============================================================================
# Data Quality
# =============================================================================
DATA_AUDIT_ENABLED=true

# =============================================================================
# Feature Flags (Phase 2-3)
# =============================================================================
PHI_ACCRUAL_ENABLED=true
USE_CROSS_ENCODER_ONLY=false
USE_GATEWAY_SERVICE=false

# =============================================================================
# Node Model Overrides (JSON dict)
# =============================================================================
NODE_MODEL_OVERRIDES={}

# =============================================================================
# Docker Container Overrides (set by docker-compose.prod.yml)
# =============================================================================
PYTHON_MEMORY_LIMIT_MB=2048

# =============================================================================
# Thread Control (Prevents OOM / CPU thrashing for ML inference)
# =============================================================================
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1
VECLIB_MAXIMUM_THREADS=1
NUMEXPR_NUM_THREADS=1
TOKENIZERS_PARALLELISM=false


=============================================================================
# Google Auth for Supabase and Supabase as Postgres
# =============================================================================
VITE_SUPABASE_URL=https://ozmjeuqbholoxypfxixb.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xiLP47LDiH7JKMf1GfLhng_6MZfd8JC

