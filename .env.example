# ============================================================
# Mukthi Guru — Root Environment Configuration (Example)
# Copy to .env and fill in values. Do NOT commit .env to git.
#
# The canonical .env.example lives at backend/.env.example.
# This root-level file mirrors the key groups needed at the
# top level for docker-compose and supabase CLI usage.
# ============================================================

# === LLM PROVIDER ===
# Options: "sarvam_cloud", "ollama", "openrouter", "nim"
LLM_PROVIDER=sarvam_cloud

# === SARVAM CLOUD API ===
SARVAM_API_KEY=
SARVAM_CLOUD_MODEL=sarvam-30b
SARVAM_CLOUD_CLASSIFY_MODEL=sarvam-30b
SARVAM_RPM_LIMIT=60

# === OPENROUTER ===
OPENROUTER_API_KEY=
OPENROUTER_GENERATION_MODEL=meta-llama/llama-3.1-8b-instruct
OPENROUTER_CLASSIFY_MODEL=meta-llama/llama-3.1-8b-instruct
OPENROUTER_FAST_MODEL=meta-llama/llama-3.1-8b-instruct

# === NVIDIA NIM ===
NIM_API_KEY=
NIM_GENERATION_MODEL=meta/llama-3.1-8b-instruct
NIM_CLASSIFY_MODEL=meta/llama-3.1-8b-instruct
NIM_RPM_LIMIT=30

# === OLLAMA / LOCAL MODELS ===
MODEL_PRESET=qwen
OLLAMA_MODEL=
OLLAMA_CLASSIFY_MODEL=
OLLAMA_BASE_URL=http://localhost:11434

# === INFRASTRUCTURE ===
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=spiritual_wisdom
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# === SUPABASE ===
SUPABASE_URL=http://localhost:54321
PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_KEY=
JWT_SECRET=
SUPABASE_ANON_KEY=

# === OAUTH ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# === SERVER ===
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080
RATE_LIMIT_PER_MINUTE=10

# === GUARDRAILS ===
GUARDRAILS_PROVIDER=lightweight
HF_TOKEN=

# === RAG PIPELINE ===
RAG_TOP_K_RETRIEVAL=20
RAG_TOP_K_RERANK=5
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# === BENCHMARKS (LOCAL DEV ONLY) ===
IS_PRODUCTION=false
ENABLE_TEST_AUTH=false
BENCHMARK_SECRET=

# === RESOURCE CONTROL ===
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
TOKENIZERS_PARALLELISM=false

# === WEB SEARCH ===
WEB_SEARCH_ENABLED=false
BM25_RETRIEVAL_ENABLED=false

# --- Mobile App (Capacitor) ---
VITE_BACKEND_URL=https://askmukthiguru-8119b0e8-production.up.railway.app

# --- Admin UI Bundle Stripping (Frontend) ---
# Set to 'false' to strip admin routes + admin page chunks from the production
# bundle entirely (Vite tree-shakes the dead branch). Useful for public-facing
# deployments that don't need the admin surface. Default: enabled.
VITE_ADMIN_ENABLED=true

# --- Push Notifications (Backend) ---
FIREBASE_CREDENTIALS_JSON=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_PATH=
APNS_KEY_PEM=
APNS_BUNDLE_ID=com.askmukthiguru.app

# ============================================================
# For a complete list of all configurable variables, see:
#   backend/.env.example
#   backend/app/config.py (pydantic-settings)
# ============================================================
