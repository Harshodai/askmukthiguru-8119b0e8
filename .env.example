# ============================================================================
# AskMukthiGuru — Environment Variables
# ============================================================================
# Copy this file to .env.local for local development overrides.
# Lovable Cloud auto-injects VITE_SUPABASE_* in the hosted sandbox.

# ── Backend (FastAPI) ───────────────────────────────────────────────
# Local dev: point to your local FastAPI server
# Production: leave empty (uses relative /api/chat, requires a reverse proxy)
# Or set to your deployed backend URL
VITE_BACKEND_URL=http://localhost:8000

# ── Supabase / Lovable Cloud ───────────────────────────────────────
# These are auto-injected by Lovable Cloud. Only needed for standalone
# local development outside Lovable.
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
# VITE_SUPABASE_PROJECT_ID=your-project-ref

# ── OAuth mode ─────────────────────────────────────────────────────
# false (default): use Lovable Cloud managed OAuth wrapper.
# true: use native Supabase OAuth (only for local Docker without the Lovable proxy).
VITE_USE_NATIVE_OAUTH=false
