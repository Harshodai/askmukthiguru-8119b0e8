{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "backend/Dockerfile.railway"
  },
  "deploy": {
    "startCommand": "python start_railway.py",
    "restartPolicyType": "ON_FAILURE",

    "restartPolicyMaxRetries": 3,
    "limits": {
      "cpu": 1000,
      "memory": "2Gi"
    }
  }
}
